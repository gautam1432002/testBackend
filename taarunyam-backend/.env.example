# ─── Django Core ──────────────────────────────────────────────────────────────
SECRET_KEY=your-very-long-random-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
SITE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
DB_NAME=taarunyam
DB_USER=taarunyam
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432

# ─── Redis / Celery ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ─── JWT ─────────────────────────────────────────────────────────────────────
ACCESS_TOKEN_LIFETIME_MINUTES=15
REFRESH_TOKEN_LIFETIME_DAYS=7

# ─── Fernet Encryption (for SMTP password at rest) ───────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your-base64-fernet-key-here

# ─── Admin OTP ───────────────────────────────────────────────────────────────
# Comma-separated list of authorized admin emails for OTP/password-reset
AUTHORIZED_ADMIN_EMAILS=admin@taarunyam.com,superadmin@taarunyam.com

# ─── Media / Storage ──────────────────────────────────────────────────────────
MEDIA_ROOT=media/
# Set to 's3' to use AWS S3 instead of local disk
STORAGE_BACKEND=local
# AWS_STORAGE_BUCKET_NAME=your-bucket
# AWS_ACCESS_KEY_ID=your-key-id
# AWS_SECRET_ACCESS_KEY=your-secret
# AWS_S3_REGION_NAME=ap-south-1
